#!/bin/sh
# ~/.dwlinit - Configuração Avançada do Ecossistema Archia / Protognum (Wayland)

# ⌬ 1. PADRONIZAÇÃO DO AMBIENTE XDG & WAYLAND (Evita quebra de GTK e Qt)
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_CACHE_HOME="$HOME/.cache"
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_STATE_HOME="$HOME/.local/state"

# Força os Toolkits a usarem o Wayland nativamente
export MOZ_ENABLE_WAYLAND=1
export QT_QPA_PLATFORM="wayland;xcb"
export CLUTTER_BACKEND=wayland
export GDK_BACKEND="wayland,x11"

# Integração de temas em aplicações baseadas em Qt (ex: qterminal)
export QT_QPA_PLATFORMTHEME=qt5ct

# ⌬ 2. ECO DO SISTEMA (Aviso tático impresso no log do terminal)
echo -e "\n\033[1;37m⌬ [NÚCLEO ARCHIA] Sistema Wayland (dwl) inicializado com sucesso.\033[0m"

# ⌬ 3. MAPEAMENTO DO ARSENAL MULTIMÍDIA & GRÁFICO
# Renderizador de Wallpaper para Wayland (Substituindo o antigo feh do X11)
if command -v swaybg >/dev/null 2>&1; then
    swaybg -i "$HOME/dwl/assets/dwldwl.png" -m fill &
fi

# Inicia a sua barra do sistema em segundo plano

